#### 2. NavigationService.cs (рекомендуемая версия)

```csharp
public class NavigationService
{
    public static NavigationService Instance { get; } = new();

    private readonly Stack<ViewModelBase> _navigationStack = new();

    public void NavigateTo<T>(T viewModel) where T : ViewModelBase
    {
        if (MainViewModel.Instance.CurrentPage != null)
        {
            _navigationStack.Push(MainViewModel.Instance.CurrentPage);
        }

        MainViewModel.Instance.CurrentPage = viewModel;
    }

    public void GoBack(int steps = 1)
    {
        for (int i = 0; i < steps && _navigationStack.Count > 0; i++)
        {
            MainViewModel.Instance.CurrentPage = _navigationStack.Pop();
        }
    }
}
```

