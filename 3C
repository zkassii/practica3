### 7. NavigationService (5.3)

```csharp
public class NavigationService
{
    private readonly Stack<ViewModelBase> _navigationStack = new();

    public void NavigateTo<T>(T viewModel, Action<T>? action = null) where T : ViewModelBase
    {
        if (MainViewModel.Current != null)
        {
            _navigationStack.Push(MainViewModel.Current);
            MainViewModel.Current = viewModel;
        }

        action?.Invoke(viewModel);
    }

    public void GoBack(int steps = 1)
    {
        if (_navigationStack.Count == 0) return;

        for (int i = 0; i < steps && _navigationStack.Count > 0; i++)
        {
            MainViewModel.Current = _navigationStack.Pop();
        }
    }
}
```

