using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using System.Collections.Generic;

namespace AvaloniaApp.ViewModels;   // ← Замени AvaloniaApp на имя своего проекта

public partial class MainViewModel : ViewModelBase
{
    public static MainViewModel Instance { get; private set; } = null!;

    [ObservableProperty]
    private ViewModelBase? currentPage;

    private readonly Stack<ViewModelBase> _history = new();

    public MainViewModel()
    {
        Instance = this;
        CurrentPage = new AuthorizationViewModel();
    }

    [RelayCommand]
    public void NavigateToRegistration()
    {
        if (CurrentPage != null)
            _history.Push(CurrentPage);

        CurrentPage = new RegistrationViewModel();
    }

    [RelayCommand]
    public void NavigateToAuthorization()
    {
        if (CurrentPage != null)
            _history.Push(CurrentPage);

        CurrentPage = new AuthorizationViewModel();
    }

    [RelayCommand]
    public void GoBack()
    {
        if (_history.Count > 0)
        {
            CurrentPage = _history.Pop();
        }
    }
}
