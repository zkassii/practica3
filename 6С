**Готово.** Вот минимальный, чистый Avalonia проект, выполненный **точно по всем заданиям** лабораторной (без лишнего текста, комментариев и ненужного кода).

### 1. Создаём проект
```bash
dotnet new avalonia.app -o AvaloniaLab
cd AvaloniaLab
```

### 2. Устанавливаем Material.Avalonia
```bash
dotnet add package Material.Avalonia
dotnet add package Material.Avalonia.Desktop
```

### 3. App.axaml
```xml
<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="clr-namespace:Material.Styles;assembly=Material.Avalonia"
             x:Class="AvaloniaLab.App">
    <Application.Styles>
        <material:MaterialTheme BaseTheme="Light" PrimaryColor="Purple" SecondaryColor="Lime"/>
        
        <!-- 5.1.2 Общий стиль для всех Button -->
        <Style Selector="Button">
            <Setter Property="Background" Value="#FF5722"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 5.1.3 TextBox с Name="Title" -->
        <Style Selector="TextBox[Name=Title]">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Foreground" Value="#1565C0"/>
        </Style>

        <!-- 5.1.4 Button внутри StackPanel -->
        <Style Selector="StackPanel Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- 5.1.5 TextBlock с курсивом при highlight у родителя -->
        <Style Selector="Border.highlight TextBlock">
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <!-- 5.2.1 Button :pointerover -->
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#FF8A65"/>
        </Style>

        <!-- 5.2.2 TextBox disabled border -->
        <Style Selector="TextBox:disabled /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="Red"/>
        </Style>

        <!-- 5.2.3 ListBoxItem selected -->
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2196F3"/>
        </Style>

        <!-- 5.2.4 ListBoxItem четные -->
        <Style Selector="ListBoxItem:nth-child(even)">
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>

        <!-- 5.3.1 Два стиля для TextBlock -->
        <Style Selector="TextBlock.class1">
            <Setter Property="Foreground" Value="Green"/>
        </Style>
        <Style Selector="TextBlock.class2">
            <Setter Property="Foreground" Value="Red"/>
        </Style>

        <!-- 5.4 Стиль для всех наследников Button -->
        <Style Selector=":is(Button)">
            <Setter Property="Background" Value="#3F51B5"/>
        </Style>

        <!-- 5.5.1 TextBlock с FontSize=16 -->
        <Style Selector="TextBlock[FontSize=16]">
            <Setter Property="Foreground" Value="Orange"/>
        </Style>
    </Application.Styles>
</Application>
```

### 4. MainView.axaml
```xml
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AvaloniaLab.MainView">

    <StackPanel Margin="20" Spacing="10">
        <!-- 5.1.2 Button -->
        <Button Content="Обычная кнопка"/>

        <!-- 5.1.3 TextBox Title -->
        <TextBox Name="Title" Text="Это заголовок" Watermark="Title"/>

        <!-- 5.1.4 Кнопки внутри StackPanel -->
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Кнопка 1 в панели"/>
            <Button Content="Кнопка 2 в панели"/>
        </StackPanel>

        <!-- 5.1.5 Border с highlight -->
        <Border Classes="highlight" BorderBrush="Blue" BorderThickness="2" Padding="10">
            <TextBlock Text="Текст с курсивом внутри highlight"/>
        </Border>

        <!-- 5.2.1 Hover + 5.2.2 Disabled -->
        <Button Content="Наведи на меня"/>
        <TextBox Text="Disabled TextBox" IsEnabled="False"/>

        <!-- 5.2.3-5.2.4 ListBox -->
        <ListBox>
            <ListBoxItem Content="Элемент 1"/>
            <ListBoxItem Content="Элемент 2"/>
            <ListBoxItem Content="Элемент 3"/>
            <ListBoxItem Content="Элемент 4"/>
        </ListBox>

        <!-- 5.3 TextBlock с классами -->
        <TextBlock Classes="class1" Text="Зелёный текст"/>
        <TextBlock Classes="class2" Text="Красный текст"/>

        <!-- 5.6 Material элементы -->
        <TextBox a:TextFieldAssist.Label="TextBox" 
                 UseFloatingWatermark="True"
                 Theme="{StaticResource OutlineTextBox}"
                 Classes="outline dense"/>

        <ComboBox Theme="{StaticResource MaterialOutlineComboBox}">
            <ComboBoxItem Content="Option 1"/>
            <ComboBoxItem Content="Option 2"/>
        </ComboBox>

        <Button Content="Material кнопка"/>
    </StackPanel>
</UserControl>
```

