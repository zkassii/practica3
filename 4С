### 1. Класс User (самый простой)

**Models/User.cs**
```csharp
using System.ComponentModel;

namespace AvaloniaApp.Models
{
    public class User : INotifyPropertyChanged
    {
        public string Login { get; set; } = "";
        public string Password { get; set; } = "";

        public event PropertyChangedEventHandler? PropertyChanged;
    }
}
```

### 2. ViewModel (самая простая)

**ViewModels/UserListViewModel.cs**
```csharp
using System.Collections.ObjectModel;
using AvaloniaApp.Models;

namespace AvaloniaApp.ViewModels
{
    public class UserListViewModel
    {
        public ObservableCollection<User> Users { get; set; } = new();

        public string NewLogin { get; set; } = "";
        public string NewPassword { get; set; } = "";

        public UserListViewModel()
        {
            // тестовые данные
            Users.Add(new User { Login = "admin", Password = "123" });
            Users.Add(new User { Login = "user", Password = "qwerty" });
        }

        public void AddUser()
        {
            if (!string.IsNullOrWhiteSpace(NewLogin))
            {
                Users.Add(new User 
                { 
                    Login = NewLogin, 
                    Password = NewPassword 
                });

                NewLogin = "";
                NewPassword = "";
            }
        }

        public void DeleteUser(User user)
        {
            if (user != null)
                Users.Remove(user);
        }
    }
}
```

### 3. Страница с ListBox (UserListView.axaml)

**Views/UserListView.axaml**
```xml
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="AvaloniaApp.Views.UserListView">

    <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">
        
        <!-- Поля добавления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <TextBox Width="200" PlaceholderText="Логин" Text="{Binding NewLogin}"/>
            <TextBox Width="200" PlaceholderText="Пароль" Text="{Binding NewPassword}"/>
            <Button Content="Добавить" Click="AddButton_Click"/>
        </StackPanel>

        <!-- ListBox -->
        <ListBox Grid.Row="2" ItemsSource="{Binding Users}" Margin="0,20,0,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <TextBlock Text="{Binding Login}" Width="180"/>
                        <TextBlock Text="{Binding Password}" Width="180"/>
                        <Button Content="Удалить" 
                                Click="DeleteButton_Click"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</UserControl>
```

**Views/UserListView.axaml.cs**
```csharp
using Avalonia.Controls;
using Avalonia.Interactivity;
using AvaloniaApp.Models;
using AvaloniaApp.ViewModels;

namespace AvaloniaApp.Views
{
    public partial class UserListView : UserControl
    {
        private readonly UserListViewModel _vm = new();

        public UserListView()
        {
            InitializeComponent();
            DataContext = _vm;
        }

        private void AddButton_Click(object sender, RoutedEventArgs e)
        {
            _vm.AddUser();
        }

        private void DeleteButton_Click(object sender, RoutedEventArgs e)
        {
            if (sender is Button btn && btn.CommandParameter is User user)
            {
                _vm.DeleteUser(user);
            }
        }
    }
}
```

