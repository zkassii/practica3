### 3. RegistrationView.axaml

```xml
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:YourApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="550"
             x:Class="YourApp.Views.RegistrationView">

    <Design.DataContext>
        <vm:RegistrationViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="16" Margin="40" Width="360">
        <TextBlock Text="Регистрация" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0 0 0 30"/>

        <TextBox Text="{Binding Creditionals.Login, Mode=TwoWay, ValidatesOnDataErrors=True}"
                 Watermark="Логин" />

        <TextBox Text="{Binding Creditionals.Password, Mode=TwoWay, ValidatesOnDataErrors=True}"
                 Watermark="Пароль" PasswordChar="●" />

        <TextBox Text="{Binding Creditionals.ConfirmPassword, Mode=TwoWay, ValidatesOnDataErrors=True}"
                 Watermark="Подтверждение пароля" PasswordChar="●" />

        <TextBox Text="{Binding Creditionals.Email, Mode=TwoWay, ValidatesOnDataErrors=True}"
                 Watermark="Email" />

        <TextBox Text="{Binding Creditionals.Phone, Mode=TwoWay, ValidatesOnDataErrors=True}"
                 Watermark="Номер телефона" />

        <Button Content="Зарегистрироваться" 
                HorizontalAlignment="Center"
                Width="220" 
                Height="45"
                Margin="0 20 0 0"
                Command="{Binding Creditionals.ValidateAllPropertiesCommand}"/>
    </StackPanel>
</UserControl>
